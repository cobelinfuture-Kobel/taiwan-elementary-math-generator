            "b": "一至四位數加數",
            "sum": "加法結果"
          },
          "unknownRoles": ["sum"],
          "numberConstraints": [
            "1000 <= a <= 9999",
            "1 <= b <= 9999",
            "0 <= sum <= 9999",
            "carry count across ones tens hundreds is at least 2",
            "no carry into ten-thousands"
          ],
          "equivalentForms": [
            "a + b = sum",
            "sum - a = b",
            "sum - b = a"
          ],
          "answerType": "integer",
          "validationInvariants": [
            "sum equals a + b",
            "at least two checked columns generate a carry",
            "result remains within the four-digit worksheet boundary"
          ]
