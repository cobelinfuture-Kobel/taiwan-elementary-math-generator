{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/taiwan-elementary-math/global-kp-prerequisite-edge.schema.json",
  "title": "Global KnowledgePoint Prerequisite Edge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "edgeId",
    "fromKnowledgePointId",
    "toKnowledgePointId",
    "dependencyStrength",
    "dependencyRole",
    "alternativeGroupId",
    "isImmediatePrerequisite",
    "distanceBearing",
    "rationale",
    "evidenceRefs",
    "status",
    "introducedVersion"
  ],
  "properties": {
    "edgeId": {
      "type": "string",
      "pattern": "^kpe_r03_[0-9]{4}$"
    },
    "fromKnowledgePointId": {
      "type": "string",
      "pattern": "^kp_[a-z0-9_]+$"
    },
    "toKnowledgePointId": {
      "type": "string",
      "pattern": "^kp_[a-z0-9_]+$"
    },
    "dependencyStrength": {
      "enum": [
        "required",
        "alternative",
        "supporting"
      ]
    },
    "dependencyRole": {
      "enum": [
        "conceptual_foundation",
        "procedural_foundation",
        "relation_model_foundation",
        "representation_foundation",
        "domain_extension_foundation"
      ]
    },
    "alternativeGroupId": {
      "type": [
        "string",
        "null"
      ]
    },
    "isImmediatePrerequisite": {
      "type": "boolean"
    },
    "distanceBearing": {
      "type": "boolean"
    },
    "rationale": {
      "type": "string",
      "minLength": 12
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^source:g[3-6][ab]_u[0-9]{2}_[a-z0-9]+$"
      }
    },
    "status": {
      "const": "approved"
    },
    "introducedVersion": {
      "const": "1.0.0"
    }
  }
}
