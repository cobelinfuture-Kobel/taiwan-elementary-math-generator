    "equal_partition_all_segment_counts": {"contract": "total 2..9999 and closed unit role"},
    "equal_partition_range_constrained_recipients": {"contract": "total 2..9999 and closed count interval"},
    "problem_type_classification": {"contract": "controlled quantity-role semantic record"},
    "complete_factor_list_unknown_values": {"contract": "complete ascending symbolic factor list"},
    "complete_factor_list_statement_evaluation": {"contract": "reconstructed complete factor list and closed statements"},
    "remainder_transfer": {"contract": "D>d>=2, D%d=0, q>=0, 0<=r<D, N=qD+r"},
    "common_factor_concept_identification": {"contract": "two targets and closed candidate set"},
    "common_factor_enumeration": {"contract": "two targets 2..999"},
    "greatest_common_factor": {"contract": "two targets 2..999"},
    "maximum_equal_grouping": {"contract": "two quantities 2..9999 and maximum grouping language"},
    "possible_equal_packaging_counts": {"contract": "two quantities 2..9999 and no-leftover packaging"},
    "rectangle_square_side_lengths": {"contract": "length,width 2..999 and length unit"},
    "square_tile_area_possibilities": {"contract": "length,width 2..999 and squared answer unit"},
