{
  "schemaName": "G5AU02PatternSpecRulesAndOverlays",
  "schemaVersion": 1,
  "task": "S82_G5A_U02_PatternSpecContractDesign",
  "globalBoundary": {
    "targetNumberRange": [2, 999],
    "pairedNumberRange": [2, 999],
    "applicationQuantityRange": [2, 9999],
    "geometryDimensionRange": [2, 999],
    "digitRange": [0, 9],
    "digitCodeLength": 4,
    "positiveIntegerOnly": true,
    "includeOneAndSelfAsFactors": true,
    "factorListOrdering": "ascending_unique",
    "zeroDivisorAllowed": false,
    "leadingZeroAllowedInDigitCode": false,
    "fractionalAnswerAllowed": false,
    "negativeAnswerAllowed": false,
    "shortDivisionExternalMediaInferenceAllowed": false,
    "genericFallbackAllowed": false
  },
  "formalRules": {
    "divides": "d>0 && n%d===0",
    "factorSet": "sortAsc({d in Z | 1<=d<=n && n%d=0})",
    "factorPairs": "sortByFirst({(a,n/a) | 1<=a<=floor(sqrt(n)) && n%a=0})",
    "factorListFromPairs": "sortAsc(unique(flatten(factorPairs(n))))",
    "commonFactorSet": "intersect(factorSet(a),factorSet(b))",
    "greatestCommonFactor": "max(commonFactorSet(a,b))",
    "missingFactorValues": "project factorSet(n) onto hidden positions while all visible positions remain fixed",
    "equalPartitionSolutions": "filter(factorSet(total), closed context range and unit constraints)",
    "targetParity": "n is even iff 2 in factorSet(n)",
    "factorCountParity": "factorSet(n).length is odd iff n is a perfect square (isPerfectSquare(n))",
    "remainderTransfer": "if D>d>=2 && D%d=0 && q>=0 && 0<=r<D && N=q*D+r, then N%d=r%d and 0<=N%d<d",
    "rectangleSquareSideLengths": "commonFactorSet(length,width)",
    "squareTileAreas": "sortAsc({s*s | s in commonFactorSet(length,width)})",
    "problemTypeClassification": "choose exactly one of factor|multiple|common_factor|common_multiple from closed quantity-role and extremum-language rules",
    "digitCodeSolutions": "enumerate x1..x4 in 0..9 with x1>0,x2>0,x4>0; x1 divides 22,33,45,60; x3 divides 6,8 and x3!=x1; x2 divides 70 and x4 divides 70; value divisible by 3 and 5; all digits distinct; require exactly one tuple"
  },
  "identifierRules": {
    "patternSpecIdPattern": "^ps_g5a_u02_[a-z0-9_]+$",
    "patternGroupIdPattern": "^pg_g5a_u02_[a-z0-9_]+$",
    "knowledgePointIdPattern": "^kp_g5a_u02_[a-z0-9_]+$",
    "mappingCandidateIdPattern": "^fmc_g5a_u02_[a-z0-9_]+$",
    "templateFamilyIdPattern": "^tpl_g5a_u02_[a-z0-9_]+$",
    "allIdsUnique": true
  },
  "inputContracts": {
