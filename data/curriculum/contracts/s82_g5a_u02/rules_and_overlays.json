      "requiredGuards": ["larger_and_smaller_divisors_positive_and_ordered", "larger_divisor_multiple_of_smaller", "known_remainder_in_standard_range", "division_witness_reconstructs_total", "transferred_remainder_reduced_mod_smaller"]
    },
    {
      "correctionCode": "S81_DIGIT_CODE_POSITIONAL_PREDICATES_REQUIRED",
