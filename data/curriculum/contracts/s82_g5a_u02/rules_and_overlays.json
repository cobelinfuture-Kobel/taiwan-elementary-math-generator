      "requiredGuards": ["source_predicates_bound_to_exact_digit_positions", "common_multiple_witness_means_each_positive_digit_divides_70", "lcm_equals_70_substitution_forbidden", "whole_number_divisible_by_3_and_5", "all_four_digits_distinct", "exactly_one_solution", "no_unstated_constraint"]
