      "targetPatternSpecId": "ps_g5a_u02_factor_relation_equivalence",
      "effectiveContract": "for positive integers n and d, d is a factor of n iff there exists positive q with d*q=n iff n%d=0; a displayed a*b=n witnesses complementary factors but arbitrary factors need not multiply to n",
      "requiredGuards": ["positive_integer_target_divisor_and_quotient", "quotient_equals_target_divided_by_divisor", "multiplication_and_division_witnesses_equivalent", "arbitrary_factor_pair_converse_forbidden", "factor_multiple_direction_not_reversed"]
    },
    {
