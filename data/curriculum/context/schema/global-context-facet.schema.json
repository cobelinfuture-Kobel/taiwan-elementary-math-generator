{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cobelinfuture-Kobel/taiwan-elementary-math-generator/data/curriculum/context/schema/global-context-facet.schema.json",
  "title": "GlobalContextFacetV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "facetId",
    "axis",
    "labelZh",
    "descriptionZh",
    "lifecycle",
    "sourceRefs"
  ],
  "properties": {
    "facetId": {
      "type": "string",
      "pattern": "^facet_[a-z0-9_]+$"
    },
    "axis": {
      "enum": [
        "SDG_GOAL",
        "TEMPORAL_LENS",
        "GEOGRAPHY_LENS",
        "THEME",
        "DATA_FRESHNESS"
      ]
    },
    "labelZh": {
      "type": "string",
      "minLength": 2
    },
    "descriptionZh": {
      "type": "string",
      "minLength": 5
    },
    "lifecycle": {
      "enum": [
        "DRAFT",
        "SEMANTIC_REVIEW_READY",
        "QA_VALIDATED",
        "PRODUCTION_ADMITTED",
        "REJECTED",
        "DEFERRED"
      ]
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    }
  }
}
