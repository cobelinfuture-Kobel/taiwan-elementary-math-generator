{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GlobalContextFusionSituationSeedV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["seedId","macroContextId","mesoSituationId","mesoLabelZh","microScenarioId","microLabelZh","eventGoal","actorRoles","resourceRoles","eventFlow","constraintModel","targetRoles","interpretiveActs","decisionModels","requiredContextAffordances","compatibleOperationFamilies","facetRefs","surfaceTemplatePrefix","sourcePolicy","sourceRefs"],
  "properties": {
    "seedId": {"type":"string","pattern":"^gctx_seed_"},
    "macroContextId": {"type":"string","pattern":"^gctx_macro_"},
    "mesoSituationId": {"type":"string","pattern":"^gctx_meso_"},
    "mesoLabelZh": {"type":"string","minLength":2},
    "mesoDescriptionZh": {"type":"string"},
    "microScenarioId": {"type":"string","pattern":"^gctx_micro_"},
    "microLabelZh": {"type":"string","minLength":2},
    "microDescriptionZh": {"type":"string"},
    "eventGoal": {"type":"string","minLength":3},
    "actorRoles": {"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true},
    "actorRelationship": {"type":"string"},
    "resourceRoles": {"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true},
    "eventFlow": {"type":"array","minItems":2,"items":{"type":"string"}},
    "constraintModel": {"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true},
    "targetRoles": {"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true},
    "interpretiveActs": {"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true},
    "decisionModels": {"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true},
    "requiredContextAffordances": {"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true},
    "compatibleOperationFamilies": {"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true},
    "facetRefs": {"type":"array","minItems":2,"items":{"type":"string","pattern":"^facet_"},"uniqueItems":true},
    "legacyFamilyRef": {"type":"string","pattern":"^gctx_family_"},
    "legacySurfaceTemplateIds": {"type":"array","items":{"type":"string","pattern":"^tpl_"},"uniqueItems":true},
    "surfaceTemplatePrefix": {"type":"string","pattern":"^tpl_fusion_"},
    "sourcePolicy": {"enum":["FICTIONALIZED_PRACTICE_DATA","CURRENT_AFFAIRS_SOURCE_REQUIRED"]},
    "currentAffairsAnchorRefs": {"type":"array","items":{"type":"string","pattern":"^ca_"},"uniqueItems":true},
    "sourceRefs": {"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true}
  },
  "allOf": [{"if":{"properties":{"sourcePolicy":{"const":"CURRENT_AFFAIRS_SOURCE_REQUIRED"}}},"then":{"required":["currentAffairsAnchorRefs"],"properties":{"currentAffairsAnchorRefs":{"minItems":1}}}}]
}
