{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taiwan-elementary-math-generator.example/schemas/gctx-scenario-chain-bounded-pbl-v1.json",
  "title": "GCTX ScenarioChain and BoundedPBL Schema",
  "description": "Approved 2–5 question scenario chains and bounded PBL chains. Every question-count profile is an independently approved complete projection; runtime truncation and ad-hoc question assembly are forbidden.",
  "$defs": {
    "lifecycleStatus": {
      "type": "string",
      "enum": ["candidate", "reviewed", "approved", "deprecated", "blocked", "rejected"]
    },
    "itemStructureClass": {
      "type": "string",
      "enum": [
        "independent_application",
        "common_scenario_independent",
        "scenario_chain_dependent",
        "bounded_pbl_closed"
      ]
    },
    "dependencyGraphType": {
      "type": "string",
      "enum": [
        "common_scenario_independent",
        "linear_dependency",
        "branch_merge",
        "parallel_comparison",
        "constraint_merge"
      ]
    },
    "sharedEntity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entityId", "slotKind", "assetId", "semanticRole", "stableAcrossProjection"],
      "properties": {
        "entityId": {"type": "string", "pattern": "^entity_[a-z0-9_]+$"},
        "slotKind": {
          "type": "string",
          "enum": ["actor", "place", "object", "activity", "classifier", "unit", "option"]
        },
        "assetId": {"type": "string", "minLength": 1},
        "semanticRole": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "stableAcrossProjection": {"const": true}
      }
    },
    "subquestionNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subquestionId",
        "order",
        "approvedSemanticBindingId",
        "questionFunction",
        "dependsOnSubquestionIds",
        "consumesQuantityIds",
        "producesQuantityIds",
        "coversMilestoneIds",
        "terminalForProjection"
      ],
      "properties": {
        "subquestionId": {"type": "string", "pattern": "^sq_[a-z0-9_]+$"},
        "order": {"type": "integer", "minimum": 1, "maximum": 5},
        "approvedSemanticBindingId": {
          "type": "string",
          "pattern": "^gctx_binding_[a-z0-9_]+$"
        },
        "questionFunction": {
          "type": "string",
          "enum": [
            "read_or_extract_data",
            "establish_quantity",
            "compute_intermediate",
            "compare_results",
            "evaluate_constraint",
            "select_option",
            "complete_plan",
            "state_conclusion"
          ]
        },
        "dependsOnSubquestionIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^sq_[a-z0-9_]+$"}
        },
        "consumesQuantityIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^chain_qty_[a-z0-9_]+$"}
        },
        "producesQuantityIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^chain_qty_[a-z0-9_]+$"}
        },
        "coversMilestoneIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^milestone_[a-z0-9_]+$"}
        },
        "terminalForProjection": {"type": "boolean"}
      }
    },
    "dependencyEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fromSubquestionId", "toSubquestionId", "dependencyType", "quantityIds", "required"],
      "properties": {
        "fromSubquestionId": {"type": "string", "pattern": "^sq_[a-z0-9_]+$"},
        "toSubquestionId": {"type": "string", "pattern": "^sq_[a-z0-9_]+$"},
        "dependencyType": {
          "type": "string",
          "enum": ["result", "quantity", "decision_evidence", "shared_state"]
        },
        "quantityIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^chain_qty_[a-z0-9_]+$"}
        },
        "required": {"const": true}
      }
    },
    "quantityLedgerEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quantityId",
        "semanticRole",
        "unitDimension",
        "originType",
        "originReferenceId",
        "visibleBeforeSubquestionIds",
        "consumedBySubquestionIds",
        "derivationRuleId",
        "immutableWithinProjection"
      ],
      "properties": {
        "quantityId": {"type": "string", "pattern": "^chain_qty_[a-z0-9_]+$"},
        "semanticRole": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "unitDimension": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "originType": {
          "type": "string",
          "enum": ["stimulus", "precomputed_visible", "subquestion_output"]
        },
        "originReferenceId": {"type": "string", "minLength": 1},
        "visibleBeforeSubquestionIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^sq_[a-z0-9_]+$"}
        },
        "consumedBySubquestionIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^sq_[a-z0-9_]+$"}
        },
        "derivationRuleId": {"type": ["string", "null"]},
        "immutableWithinProjection": {"const": true}
      }
    },
    "requiredMilestone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["milestoneId", "order", "milestoneFunction", "required"],
      "properties": {
        "milestoneId": {"type": "string", "pattern": "^milestone_[a-z0-9_]+$"},
        "order": {"type": "integer", "minimum": 1},
        "milestoneFunction": {
          "type": "string",
          "enum": [
            "establish_supply",
            "establish_demand",
            "establish_capacity",
            "establish_cost",
            "establish_time",
            "establish_measure",
            "evaluate_balance",
            "compare_options",
            "apply_constraint",
            "make_decision",
            "complete_deliverable",
            "approved_custom_milestone"
          ]
        },
        "required": {"const": true}
      }
    },
    "milestoneCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "milestoneId",
        "coverageMode",
        "subquestionIds",
        "evidenceQuantityIds",
        "accounted",
        "silentlyRemoved"
      ],
      "properties": {
        "milestoneId": {"type": "string", "pattern": "^milestone_[a-z0-9_]+$"},
        "coverageMode": {
          "type": "string",
          "enum": [
            "question",
            "supplied_as_stimulus",
            "merged_into_question",
            "precomputed_and_visible"
          ]
        },
        "subquestionIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^sq_[a-z0-9_]+$"}
        },
        "evidenceQuantityIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^chain_qty_[a-z0-9_]+$"}
        },
        "accounted": {"const": true},
        "silentlyRemoved": {"const": false}
      },
      "allOf": [
        {
          "if": {
            "properties": {"coverageMode": {"enum": ["question", "merged_into_question"]}},
            "required": ["coverageMode"]
          },
          "then": {"properties": {"subquestionIds": {"minItems": 1}}}
        },
        {
          "if": {
            "properties": {
              "coverageMode": {"enum": ["supplied_as_stimulus", "precomputed_and_visible"]}
            },
            "required": ["coverageMode"]
          },
          "then": {
            "properties": {
              "subquestionIds": {"maxItems": 0},
              "evidenceQuantityIds": {"minItems": 1}
            }
          }
        }
      ]
    },
    "decisionCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "criterionId",
        "criterionKind",
        "referencedQuantityIds",
        "appliedBySubquestionId",
        "deterministic"
      ],
      "properties": {
        "criterionId": {"type": "string", "pattern": "^criterion_[a-z0-9_]+$"},
        "criterionKind": {
          "type": "string",
          "enum": [
            "minimum_cost",
            "capacity_sufficient",
            "time_limit",
            "budget_limit",
            "least_waste",
            "fair_distribution",
            "safety_reserve",
            "approved_custom_rule"
          ]
        },
        "referencedQuantityIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^chain_qty_[a-z0-9_]+$"}
        },
        "appliedBySubquestionId": {"type": "string", "pattern": "^sq_[a-z0-9_]+$"},
        "deterministic": {"const": true}
      }
    },
    "terminalOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcomeId", "outcomeKind", "producedBySubquestionId", "required"],
      "properties": {
        "outcomeId": {"type": "string", "pattern": "^outcome_[a-z0-9_]+$"},
        "outcomeKind": {
          "type": "string",
          "enum": [
            "answer_set_complete",
            "selected_option",
            "completed_plan",
            "resource_allocation",
            "schedule",
            "sufficiency_judgement",
            "computed_value_set",
            "comparison_conclusion"
          ]
        },
        "producedBySubquestionId": {"type": "string", "pattern": "^sq_[a-z0-9_]+$"},
        "required": {"const": true}
      }
    },
    "projectionBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projectionKind",
        "approvedBreakAfterSubquestionId",
        "rendererMayMoveBreak",
        "semanticBlockMayBeTruncated"
      ],
      "properties": {
        "projectionKind": {
          "type": "string",
          "enum": ["single_page_complete", "approved_two_page_complete"]
        },
        "approvedBreakAfterSubquestionId": {"type": ["string", "null"]},
        "rendererMayMoveBreak": {"const": false},
        "semanticBlockMayBeTruncated": {"const": false}
      },
      "allOf": [
        {
          "if": {
            "properties": {"projectionKind": {"const": "single_page_complete"}},
            "required": ["projectionKind"]
          },
          "then": {"properties": {"approvedBreakAfterSubquestionId": {"type": "null"}}}
        },
        {
          "if": {
            "properties": {"projectionKind": {"const": "approved_two_page_complete"}},
            "required": ["projectionKind"]
          },
          "then": {
            "properties": {
              "approvedBreakAfterSubquestionId": {
                "type": "string",
                "pattern": "^sq_[a-z0-9_]+$"
              }
            }
          }
        }
      ]
    },
    "closureAssertions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allRequiredMilestonesCovered",
        "dependencyGraphAcyclic",
        "allConsumedQuantitiesAvailable",
        "noOrphanSubquestions",
        "terminalOutcomeReached",
        "projectGoalReached",
        "runtimeTruncationAllowed",
        "runtimeQuestionAssemblyAllowed",
        "completeProjection"
      ],
      "properties": {
        "allRequiredMilestonesCovered": {"const": true},
        "dependencyGraphAcyclic": {"const": true},
        "allConsumedQuantitiesAvailable": {"const": true},
        "noOrphanSubquestions": {"const": true},
        "terminalOutcomeReached": {"const": true},
        "projectGoalReached": {"type": "boolean"},
        "runtimeTruncationAllowed": {"const": false},
        "runtimeQuestionAssemblyAllowed": {"const": false},
        "completeProjection": {"const": true}
      }
    },
    "completeQuestionCountProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profileId",
        "questionCount",
        "dependencyGraphType",
        "subquestions",
        "dependencyEdges",
        "quantityLedger",
        "milestoneCoverage",
        "decisionCriteria",
        "terminalOutcome",
        "projectionBoundary",
        "closureAssertions",
        "approvalState"
      ],
      "properties": {
        "profileId": {"type": "string", "pattern": "^profile_[a-z0-9_]+$"},
        "questionCount": {"type": "integer", "minimum": 2, "maximum": 5},
        "dependencyGraphType": {"$ref": "#/$defs/dependencyGraphType"},
        "subquestions": {
          "type": "array",
          "minItems": 2,
          "maxItems": 5,
          "items": {"$ref": "#/$defs/subquestionNode"}
        },
        "dependencyEdges": {
          "type": "array",
          "items": {"$ref": "#/$defs/dependencyEdge"}
        },
        "quantityLedger": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/quantityLedgerEntry"}
        },
        "milestoneCoverage": {
          "type": "array",
          "items": {"$ref": "#/$defs/milestoneCoverage"}
        },
        "decisionCriteria": {
          "type": "array",
          "items": {"$ref": "#/$defs/decisionCriterion"}
        },
        "terminalOutcome": {"$ref": "#/$defs/terminalOutcome"},
        "projectionBoundary": {"$ref": "#/$defs/projectionBoundary"},
        "closureAssertions": {"$ref": "#/$defs/closureAssertions"},
        "approvalState": {"const": "approved"}
      }
    },
    "chainValidationContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blocking",
        "approvedP01BindingsRequired",
        "questionCountMatchesProfileRequired",
        "uniqueSubquestionIdsRequired",
        "dependencyReferencesValidRequired",
        "dependencyGraphAcyclicRequired",
        "quantityLedgerClosedRequired",
        "milestoneCoverageCompleteRequired",
        "terminalOutcomeRequired",
        "canonicalAnswerRecomputationPerQuestionRequired",
        "canonicalChainRecomputationRequired",
        "runtimeTruncationForbidden",
        "runtimeQuestionAssemblyForbidden",
        "undeclaredPageSplitForbidden"
      ],
      "properties": {
        "blocking": {"const": true},
        "approvedP01BindingsRequired": {"const": true},
        "questionCountMatchesProfileRequired": {"const": true},
        "uniqueSubquestionIdsRequired": {"const": true},
        "dependencyReferencesValidRequired": {"const": true},
        "dependencyGraphAcyclicRequired": {"const": true},
        "quantityLedgerClosedRequired": {"const": true},
        "milestoneCoverageCompleteRequired": {"const": true},
        "terminalOutcomeRequired": {"const": true},
        "canonicalAnswerRecomputationPerQuestionRequired": {"const": true},
        "canonicalChainRecomputationRequired": {"const": true},
        "runtimeTruncationForbidden": {"const": true},
        "runtimeQuestionAssemblyForbidden": {"const": true},
        "undeclaredPageSplitForbidden": {"const": true}
      }
    },
    "scenarioChainEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenarioChainId",
        "rulesetVersion",
        "unitCode",
        "knowledgePointIds",
        "patternSpecIds",
        "itemStructureClass",
        "scenarioPurpose",
        "sharedStemAssetId",
        "sharedEntities",
        "requiredMilestones",
        "approvedQuestionCountProfiles",
        "validationContract",
        "lifecycleStatus"
      ],
      "properties": {
        "scenarioChainId": {"type": "string", "pattern": "^gctx_scenario_[a-z0-9_]+$"},
        "rulesetVersion": {"const": "0.1.0"},
        "unitCode": {"type": "string", "minLength": 1},
        "knowledgePointIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "patternSpecIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "itemStructureClass": {
          "type": "string",
          "enum": ["common_scenario_independent", "scenario_chain_dependent"]
        },
        "scenarioPurpose": {"type": "string", "minLength": 1},
        "sharedStemAssetId": {"type": "string", "minLength": 1},
        "sharedEntities": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/sharedEntity"}
        },
        "requiredMilestones": {
          "type": "array",
          "items": {"$ref": "#/$defs/requiredMilestone"}
        },
        "approvedQuestionCountProfiles": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/completeQuestionCountProfile"}
        },
        "validationContract": {"$ref": "#/$defs/chainValidationContract"},
        "lifecycleStatus": {"$ref": "#/$defs/lifecycleStatus"}
      }
    },
    "boundedPblEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pblChainId",
        "rulesetVersion",
        "unitCode",
        "knowledgePointIds",
        "patternSpecIds",
        "itemStructureClass",
        "projectArchetypeId",
        "projectGoal",
        "sharedStemAssetId",
        "sharedEntities",
        "requiredMilestones",
        "decisionCriteria",
        "terminalDeliverableContract",
        "approvedQuestionCountProfiles",
        "pblApprovalAsWhole",
        "validationContract",
        "lifecycleStatus"
      ],
      "properties": {
        "pblChainId": {"type": "string", "pattern": "^gctx_pbl_[a-z0-9_]+$"},
        "rulesetVersion": {"const": "0.1.0"},
        "unitCode": {"type": "string", "minLength": 1},
        "knowledgePointIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "patternSpecIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "itemStructureClass": {"const": "bounded_pbl_closed"},
        "projectArchetypeId": {"type": "string", "pattern": "^pbl_archetype_[a-z0-9_]+$"},
        "projectGoal": {"type": "string", "minLength": 1},
        "sharedStemAssetId": {"type": "string", "minLength": 1},
        "sharedEntities": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/sharedEntity"}
        },
        "requiredMilestones": {
          "type": "array",
          "minItems": 2,
          "items": {"$ref": "#/$defs/requiredMilestone"}
        },
        "decisionCriteria": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/decisionCriterion"}
        },
        "terminalDeliverableContract": {"$ref": "#/$defs/terminalOutcome"},
        "approvedQuestionCountProfiles": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/completeQuestionCountProfile"}
        },
        "pblApprovalAsWhole": {"const": true},
        "validationContract": {"$ref": "#/$defs/chainValidationContract"},
        "lifecycleStatus": {"$ref": "#/$defs/lifecycleStatus"}
      }
    },
    "registryEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "rulesetVersion", "scenarioChains", "boundedPblChains"],
      "properties": {
        "schemaVersion": {"const": "gctx-scenario-chain-bounded-pbl-v1"},
        "rulesetVersion": {"const": "0.1.0"},
        "scenarioChains": {
          "type": "array",
          "items": {"$ref": "#/$defs/scenarioChainEntry"}
        },
        "boundedPblChains": {
          "type": "array",
          "items": {"$ref": "#/$defs/boundedPblEntry"}
        }
      }
    }
  },
  "$ref": "#/$defs/registryEnvelope"
}
