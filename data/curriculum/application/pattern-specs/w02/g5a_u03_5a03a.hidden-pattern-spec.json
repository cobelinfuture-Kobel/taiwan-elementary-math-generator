          "operationModelId": "op_g5a_u03a_bounded_or_nearest_multiple",
          "operationFamilyId": "nearest_multiple",
          "mode": "NUMERIC",
          "requestedUnknownRole": "boundedMultiples",
          "givenRoles": [
            "base",
            "lower",
            "upper",
            "target",
            "nearest"
          ],
          "answerType": "integer_or_integer_list",
          "operationContract": {
            "canonicalExpressions": [
              "boundedMultiples = {base*k | lower <= base*k <= upper}",
              "nearest = argmin(abs(base*k - target))"
            ],
            "numberConstraints": [
              "base > 0",
              "lower <= upper"
            ],
            "equivalentForms": [
              "floor/ceiling quotient candidates"
            ],
            "validationInvariants": [
              "bounds are respected",
              "nearest minimizes absolute distance"
            ]
          },
