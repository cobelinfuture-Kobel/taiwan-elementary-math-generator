{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cobelinfuture-Kobel/taiwan-elementary-math-generator/data/curriculum/application/schema/w02-nplusone-proof-candidate.schema.json",
  "title": "POSTGAPPW02NPlusOneProofCandidateV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion","proofCandidateId","sourceId","sourceContentIdentityGroup","patternSpecId","requestedUnknownRole",
    "knowledgePointId","canonicalOperationModelId","bindingCandidateId","baseCapabilityId","candidateCapabilityId",
    "capabilityEdge","prerequisiteClosureCandidate","newInterpretiveAct","pairedControlBlueprint","interpretationFork",
    "interpretationWitnessBlueprint","misconceptionCandidates","counterfactualBlueprint","crossContextProofCandidate",
    "validatorDeltaCandidate","pendingProofChecks","candidateStatus","productionAdmissionAllowed","lineage"
  ],
  "properties": {
    "schemaVersion":{"const":1},
    "proofCandidateId":{"type":"string","pattern":"^w02_n1proof_"},
    "sourceId":{"type":"string"},
    "sourceContentIdentityGroup":{"type":"string","minLength":3},
    "patternSpecId":{"type":"string","pattern":"^ps_"},
    "requestedUnknownRole":{"type":"string","minLength":1},
    "knowledgePointId":{"type":"string","pattern":"^kp_"},
    "canonicalOperationModelId":{"type":"string","pattern":"^op_"},
    "bindingCandidateId":{"type":"string","pattern":"^w02_bind_"},
    "baseCapabilityId":{"type":"string","minLength":3},
    "candidateCapabilityId":{"type":"string","minLength":3},
    "capabilityEdge":{
      "type":"object","additionalProperties":false,
      "required":["from","to","shortestSemanticDistance","intermediateSemanticNodeRequired"],
      "properties":{"from":{"type":"string"},"to":{"type":"string"},"shortestSemanticDistance":{"const":1},"intermediateSemanticNodeRequired":{"const":false}}
    },
    "prerequisiteClosureCandidate":{
      "type":"object","additionalProperties":false,
      "required":["requiredPrerequisiteCapabilityIds","availablePrerequisiteCapabilityIds","missingPrerequisiteCapabilityIds","executionVerified"],
      "properties":{
        "requiredPrerequisiteCapabilityIds":{"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true},
        "availablePrerequisiteCapabilityIds":{"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true},
        "missingPrerequisiteCapabilityIds":{"type":"array","maxItems":0,"items":{"type":"string"}},
        "executionVerified":{"const":false}
      }
    },
    "newInterpretiveAct":{"enum":["UNKNOWN_ROLE_SHIFT","REMAINDER_INTERPRETATION","RELATION_CHAIN","DUAL_CONSTRAINT_RESOLUTION","CONSERVATION_OR_TRANSFER","COMPARISON_DECISION","UNIT_ROLE_INTERPRETATION","IRRELEVANT_INFORMATION_FILTER"]},
    "pairedControlBlueprint":{
      "type":"object","additionalProperties":false,
      "required":["basePromptBlueprint","candidatePromptBlueprint","baseTargetRole","candidateTargetRole","sameNumericPrerequisites","sameNumberDomain","semanticDeltaOnly","numericFixtureInstantiated"],
      "properties":{
        "basePromptBlueprint":{"type":"string","minLength":10},"candidatePromptBlueprint":{"type":"string","minLength":10},
        "baseTargetRole":{"type":"string"},"candidateTargetRole":{"type":"string"},
        "sameNumericPrerequisites":{"const":true},"sameNumberDomain":{"const":true},"semanticDeltaOnly":{"const":true},"numericFixtureInstantiated":{"const":false}
      }
    },
    "interpretationFork":{
      "type":"object","additionalProperties":false,
      "required":["forkPoint","validInterpretationPath","plausibleMisinterpretationPath","contextConditionThatResolvesFork"],
      "properties":{"forkPoint":{"type":"string","minLength":3},"validInterpretationPath":{"type":"string","minLength":3},"plausibleMisinterpretationPath":{"type":"string","minLength":3},"contextConditionThatResolvesFork":{"type":"string","minLength":3}}
    },
    "interpretationWitnessBlueprint":{
      "type":"object","additionalProperties":false,
      "required":["witnessType","promptZh","expectedEvidenceCandidate","targetsNewInterpretiveAct","canSeparateCalculationFromInterpretation","executed"],
      "properties":{
        "witnessType":{"enum":["TARGET_ROLE_SELECTION","RELATION_ORDER_SELECTION","DECISION_REASON_SELECTION","COMPARISON_EVIDENCE","ERROR_DIAGNOSIS","SHORT_ANSWER_MEANING"]},
        "promptZh":{"type":"string","minLength":3},"expectedEvidenceCandidate":{"type":"string","minLength":3},
        "targetsNewInterpretiveAct":{"const":true},"canSeparateCalculationFromInterpretation":{"const":true},"executed":{"const":false}
      }
    },
    "misconceptionCandidates":{
      "type":"array","minItems":3,"maxItems":3,
      "items":{
        "type":"object","additionalProperties":false,
        "required":["misconceptionId","misconceptionType","triggerCondition","expectedWrongDecisionCandidate","diagnosticMeaning","diagnosticClassification","severity","executed"],
        "properties":{
          "misconceptionId":{"type":"string"},
          "misconceptionType":{"enum":["TARGET_ROLE_CONFUSION","OPERATION_KEYWORD_MATCHING","QUOTIENT_ONLY","COMPUTED_NOT_INTERPRETED","RELATION_ORDER_REVERSAL","CONSTRAINT_IGNORED","UNIT_ROLE_CONFUSION","IRRELEVANT_INFORMATION_USED","COMPARISON_DIRECTION_REVERSAL","CONSERVATION_VIOLATION"]},
          "triggerCondition":{"type":"string"},"expectedWrongDecisionCandidate":{"type":"string"},"diagnosticMeaning":{"type":"string"},
          "diagnosticClassification":{"enum":["CALCULATION_FAIL","CALCULATION_PASS_INTERPRETATION_FAIL","ANSWER_ROLE_OR_UNIT_FAIL","FULL_FAIL"]},
          "severity":{"enum":["BLOCKING","DIAGNOSTIC"]},"executed":{"const":false}
        }
      }
    },
    "counterfactualBlueprint":{
      "type":"object","additionalProperties":false,
      "required":["changedContextCondition","numericPrerequisitesPreserved","expectedInterpretationChanged","expectedAnswerOrDecisionChanged","fixtureInstantiated"],
      "properties":{"changedContextCondition":{"type":"string"},"numericPrerequisitesPreserved":{"const":true},"expectedInterpretationChanged":{"const":true},"expectedAnswerOrDecisionChanged":{"const":true},"fixtureInstantiated":{"const":false}}
    },
    "crossContextProofCandidate":{
      "type":"object","additionalProperties":false,
      "required":["primaryMacroContextId","primaryAtomicEpisodeId","alternateMacroContextId","alternateAtomicEpisodeId","macroContextsDiffer","samePatternSpec","sameOperationModel","sameInterpretiveAct","sameValidatorDelta","executed"],
      "properties":{
        "primaryMacroContextId":{"type":"string","pattern":"^gctx_macro_"},"primaryAtomicEpisodeId":{"type":"string","pattern":"^gctx_episode_"},
        "alternateMacroContextId":{"type":"string","pattern":"^gctx_macro_"},"alternateAtomicEpisodeId":{"type":"string","pattern":"^gctx_episode_"},
        "macroContextsDiffer":{"const":true},"samePatternSpec":{"const":true},"sameOperationModel":{"const":true},"sameInterpretiveAct":{"const":true},"sameValidatorDelta":{"const":true},"executed":{"const":false}
      }
    },
    "validatorDeltaCandidate":{
      "type":"object","additionalProperties":false,
      "required":["baseValidatorChecks","candidateAdditionalValidatorChecks"],
      "properties":{"baseValidatorChecks":{"type":"array","minItems":1,"items":{"type":"string"}},"candidateAdditionalValidatorChecks":{"type":"array","minItems":1,"items":{"type":"string"}}}
    },
    "pendingProofChecks":{"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true},
    "candidateStatus":{"const":"N_PLUS_1_PROOF_BLUEPRINT_COMPLETE"},
    "productionAdmissionAllowed":{"const":false},
    "lineage":{
      "type":"object","additionalProperties":false,
      "required":["a02TaskId","a02BindingCandidateId","a01dPatternSpecId","nPlusOneNormativeSchema"],
      "properties":{
        "a02TaskId":{"const":"POSTG-APP-W02-A02_AtomicContextBindingAndSingleApplicationCandidateMaterialization"},
        "a02BindingCandidateId":{"type":"string","pattern":"^w02_bind_"},
        "a01dPatternSpecId":{"type":"string","pattern":"^ps_"},
        "nPlusOneNormativeSchema":{"const":"data/curriculum/application/schema/n-plus-one-interpretation-proof.schema.json"}
      }
    }
  }
}
