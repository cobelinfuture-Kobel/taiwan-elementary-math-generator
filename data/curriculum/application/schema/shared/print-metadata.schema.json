    "schemaVersion": {"const": 1},
    "questionMode": {"const": "APPLICATION"},
    "layoutIntent": {"const": "CONTENT_AWARE_SHARED_WORKSHEET"},
    "pblPagePlan": {"enum": ["NO_PBL_SECTION","APPROVED_COMPLETE_SINGLE_PAGE_CANDIDATE","APPROVED_COMPLETE_TWO_PAGE_CANDIDATE"]},
    "unapprovedPblSplitAllowed": {"const": false},
    "forbiddenVisibleLabels": {
      "type": "array",
      "const": ["算式","答：","_____"]
    },
    "rendererRouteId": {"const": "EXISTING_WORKSHEET_RENDERER_PENDING_A06"},
    "supportsPreview": {"const": false},
    "supportsPrint": {"const": false},
    "supportsAnswerKey": {"const": true},
    "dataOnlyShadow": {"const": true}
  }
}
