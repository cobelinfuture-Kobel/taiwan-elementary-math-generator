{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cobelinfuture-Kobel/taiwan-elementary-math-generator/data/curriculum/application/schema/shared/print-metadata.schema.json",
  "title": "SharedPrintMetadataV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion","questionMode","layoutIntent","pblPagePlan","unapprovedPblSplitAllowed","forbiddenVisibleLabels","rendererRouteId","supportsPreview","supportsPrint","supportsAnswerKey","dataOnlyShadow"],
