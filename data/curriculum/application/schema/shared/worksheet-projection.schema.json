{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cobelinfuture-Kobel/taiwan-elementary-math-generator/data/curriculum/application/schema/shared/worksheet-projection.schema.json",
  "title": "SharedWorksheetProjectionV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion","worksheetProjectionId","waveId","sourceNodeId","unitId","questionMode","applicationQuestionRecords","answerKeyRecords","pblTaskSetRecords","printMetadata","modeSeparation","projectionStatus","productionSelectable","publicSelectable"],
  "properties": {
    "schemaVersion": {"const": 1},
    "worksheetProjectionId": {"type": "string", "pattern": "^shared_ws_shadow_"},
    "waveId": {"const": "W02"},
    "sourceNodeId": {"type": "string", "pattern": "^g[3-6][ab]_u"},
    "unitId": {"type": "string", "pattern": "^g[3-6][ab]_u"},
    "questionMode": {"const": "APPLICATION"},
    "applicationQuestionRecords": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "answerKeyRecords": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "pblTaskSetRecords": {"type": "array", "items": {"type": "object"}},
    "printMetadata": {"type": "object"},
    "modeSeparation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["activeQuestionMode","numericPatternSpecsProjected","applicationPatternSpecsProjected","forcedStoryAuthoringAllowed"],
      "properties": {
        "activeQuestionMode": {"const": "APPLICATION"},
        "numericPatternSpecsProjected": {"const": false},
        "applicationPatternSpecsProjected": {"const": true},
        "forcedStoryAuthoringAllowed": {"const": false}
      }
    },
    "projectionStatus": {"const": "SHADOW_DATA_PROJECTION"},
    "productionSelectable": {"const": false},
    "publicSelectable": {"const": false}
  }
}
