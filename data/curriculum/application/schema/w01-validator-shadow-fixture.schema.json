{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cobelinfuture-Kobel/taiwan-elementary-math-generator/data/curriculum/application/schema/w01-validator-shadow-fixture.schema.json",
  "title": "POSTGAPPW01ValidatorShadowFixtureV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion","fixtureId","fixtureType","sourceId","knowledgePointId","canonicalOperationModelId",
    "bindingCandidateId","operationFamily","fixtureAdapterId","contextLineage","roleValues","answerPayload",
    "answerRole","answerUnitCandidate","calculationWitness","interpretationEvidence","pblEvidence",
    "expectedValidation","productionAdmissionAllowed","lineage"
  ],
  "properties": {
    "schemaVersion":{"const":1},
    "fixtureId":{"type":"string","pattern":"^w01_fixture_"},
    "fixtureType":{"enum":[
      "POSITIVE_SINGLE_APPLICATION","NEGATIVE_WRONG_ANSWER_ROLE","NEGATIVE_UNIT_MISMATCH",
      "NEGATIVE_CALCULATION_PASS_INTERPRETATION_FAIL","POSITIVE_COUNTERFACTUAL_INTERPRETATION",
      "POSITIVE_PBL_DEPENDENCY_GRAPH","NEGATIVE_PBL_DEPENDENCY_BROKEN"
    ]},
    "sourceId":{"type":"string"},
    "knowledgePointId":{"type":"string","pattern":"^kp_"},
    "canonicalOperationModelId":{"type":"string","pattern":"^op_"},
    "bindingCandidateId":{"type":"string","pattern":"^w01_bind_"},
    "operationFamily":{"enum":["addition_subtraction","multiplication_division","remainder_decision","comparison_estimation","multi_step_relation","measurement_conversion","data_summary","resource_planning"]},
    "fixtureAdapterId":{"enum":["ADDITION_OR_SUBTRACTION","MULTIPLICATION_OR_DIVISION","REMAINDER_DECISION","COMPARISON_OR_ESTIMATION","MULTI_STEP_RELATION","MEASUREMENT_CONVERSION","DATA_SUMMARY","RESOURCE_PLANNING"]},
    "contextLineage":{
      "type":"object","additionalProperties":false,
      "required":["macroContextId","mesoSituationId","microScenarioId","atomicEpisodeId","surfaceTemplateId"],
      "properties":{
        "macroContextId":{"type":"string","pattern":"^gctx_macro_"},
        "mesoSituationId":{"type":"string","pattern":"^gctx_meso_"},
        "microScenarioId":{"type":"string","pattern":"^gctx_micro_"},
        "atomicEpisodeId":{"type":"string","pattern":"^gctx_episode_"},
        "surfaceTemplateId":{"type":"string","pattern":"^tpl_"}
      }
    },
    "roleValues":{
      "type":"array","minItems":1,
      "items":{
        "type":"object","additionalProperties":false,
        "required":["mathRoleId","value","unitCandidate","isAnswerRole"],
        "properties":{
          "mathRoleId":{"type":"string"},
          "value":{"type":["number","string","object","array"]},
          "unitCandidate":{"type":"string"},
          "isAnswerRole":{"type":"boolean"}
        }
      }
    },
    "answerPayload":{"type":["number","string","object","array"]},
    "answerRole":{"type":"string"},
    "answerUnitCandidate":{"type":"string"},
    "calculationWitness":{
      "type":"object","additionalProperties":false,
      "required":["mode","inputValues","recomputedAnswerPayload","relation","calculationPass"],
      "properties":{
        "mode":{"type":"string"},
        "inputValues":{"type":"array","minItems":1,"items":{"type":"number"}},
        "recomputedAnswerPayload":{"type":["number","string","object","array"]},
        "relation":{"type":"string","minLength":3},
        "calculationPass":{"type":"boolean"}
      }
    },
    "interpretationEvidence":{
      "type":"object","additionalProperties":false,
      "required":["required","provided","interpretiveAct","statement","counterfactualApplied"],
      "properties":{
        "required":{"type":"boolean"},"provided":{"type":"boolean"},
        "interpretiveAct":{"type":["string","null"]},"statement":{"type":"string"},
        "counterfactualApplied":{"type":"boolean"}
      }
    },
    "pblEvidence":{
      "type":"object","additionalProperties":false,
      "required":["required","taskIds","milestoneIds","dependencies","finalTaskId","finalRequiredMilestoneIds"],
      "properties":{
        "required":{"type":"boolean"},
        "taskIds":{"type":"array","items":{"type":"string"},"uniqueItems":true},
        "milestoneIds":{"type":"array","items":{"type":"string"},"uniqueItems":true},
        "dependencies":{"type":"array","items":{"type":"object","required":["taskId","inputRefs"],"properties":{"taskId":{"type":"string"},"inputRefs":{"type":"array","items":{"type":"string"}}}}},
        "finalTaskId":{"type":["string","null"]},
        "finalRequiredMilestoneIds":{"type":"array","items":{"type":"string"},"uniqueItems":true}
      }
    },
    "expectedValidation":{
      "type":"object","additionalProperties":false,
      "required":["shouldPass","expectedErrorCode","expectedCalculationPass","expectedInterpretationPass","expectedPBLPass"],
      "properties":{
        "shouldPass":{"type":"boolean"},
        "expectedErrorCode":{"type":["string","null"]},
        "expectedCalculationPass":{"type":"boolean"},
        "expectedInterpretationPass":{"type":"boolean"},
        "expectedPBLPass":{"type":"boolean"}
      }
    },
    "productionAdmissionAllowed":{"const":false},
    "lineage":{
      "type":"object","additionalProperties":false,
      "required":["a01BindingCandidateId","a03PolicyPath"],
      "properties":{
        "a01BindingCandidateId":{"type":"string","pattern":"^w01_bind_"},
        "a02ProofCandidateId":{"type":"string","pattern":"^w01_n1proof_"},
        "a02PBLCandidateId":{"type":"string","pattern":"^w01_pbl_"},
        "a03PolicyPath":{"const":"data/curriculum/application/assessment/w01-validator-fixture-shadow-policy.json"}
      }
    }
  }
}
