{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cobelinfuture-Kobel/taiwan-elementary-math-generator/data/curriculum/application/schema/w02-validator-shadow-fixture.schema.json",
  "title": "POSTGAPPW02ValidatorShadowFixtureV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion","fixtureId","fixtureType","sourceId","sourceContentIdentityGroup","patternSpecId",
    "knowledgePointId","canonicalOperationModelId","bindingCandidateId","operationFamilyId","answerShape",
    "fixtureAdapterId","adapterMode","contextMode","contextLineage","roleValues","answerPayload",
    "answerRole","answerUnitCandidate","calculationWitness","pairingEvidence","interpretationEvidence",
    "misconceptionEvidence","uniquenessEvidence","pblEvidence","expectedValidation",
    "productionAdmissionAllowed","lineage"
  ],
  "properties": {
    "schemaVersion":{"const":1},
    "fixtureId":{"type":"string","pattern":"^w02_fixture_"},
    "fixtureType":{"enum":[
      "POSITIVE_SINGLE_APPLICATION","NEGATIVE_WRONG_ANSWER_ROLE","NEGATIVE_UNIT_MISMATCH",
      "POSITIVE_N_PLUS_ONE_INTERPRETATION","NEGATIVE_MISCONCEPTION",
      "POSITIVE_COUNTERFACTUAL_INTERPRETATION","POSITIVE_CROSS_CONTEXT_INTERPRETATION",
      "NEGATIVE_NON_UNIQUE_ANSWER_WITNESS","POSITIVE_PBL_DEPENDENCY_GRAPH",
      "NEGATIVE_PBL_DEPENDENCY_BROKEN"
    ]},
    "sourceId":{"type":"string","pattern":"^g[3-6][ab]_u"},
    "sourceContentIdentityGroup":{"type":"string","pattern":"^pdf_"},
    "patternSpecId":{"type":"string","pattern":"^ps_"},
    "knowledgePointId":{"type":"string","pattern":"^kp_"},
    "canonicalOperationModelId":{"type":"string","pattern":"^op_"},
    "bindingCandidateId":{"type":"string","pattern":"^w02_bind_"},
    "operationFamilyId":{"type":"string","minLength":1},
    "answerShape":{"enum":["QUANTITY_WITH_UNIT","QUOTIENT_REMAINDER","DECISION_WITH_REASON","COMPARISON_CHOICE"]},
    "fixtureAdapterId":{"enum":[
      "GENERIC_QUANTITY_RECONSTRUCTION","QUOTIENT_REMAINDER_RECONSTRUCTION",
      "BOUNDED_DECISION_RECONSTRUCTION","COMPARISON_CHOICE_RECONSTRUCTION"
    ]},
    "adapterMode":{"type":"string","minLength":1},
    "contextMode":{"enum":["PRIMARY","ALTERNATE"]},
    "contextLineage":{
      "type":"object","additionalProperties":false,
      "required":["macroContextId","mesoSituationId","microScenarioId","atomicEpisodeId","surfaceTemplateId"],
      "properties":{
        "macroContextId":{"type":"string","pattern":"^gctx_macro_"},
        "mesoSituationId":{"type":"string","pattern":"^gctx_meso_"},
        "microScenarioId":{"type":"string","pattern":"^gctx_micro_"},
        "atomicEpisodeId":{"type":"string","pattern":"^gctx_episode_"},
        "surfaceTemplateId":{"type":"string","pattern":"^tpl_"}
      }
    },
    "roleValues":{
      "type":"array","minItems":2,
      "items":{
        "type":"object","additionalProperties":false,
        "required":["mathRoleId","value","unitCandidate","isAnswerRole"],
        "properties":{
          "mathRoleId":{"type":"string","minLength":1},
          "value":{"type":["number","string","object","array"]},
          "unitCandidate":{"type":"string","minLength":1},
          "isAnswerRole":{"type":"boolean"}
        }
      }
    },
    "answerPayload":{"type":["number","string","object","array"]},
    "answerRole":{"type":"string","minLength":1},
    "answerUnitCandidate":{"type":"string","minLength":1},
    "calculationWitness":{
      "type":"object","additionalProperties":false,
      "required":["inputValues","recomputedAnswerPayload","canonicalRelation","calculationPass"],
      "properties":{
        "inputValues":{"type":"array","minItems":2,"items":{"type":"number"}},
        "recomputedAnswerPayload":{"type":["number","string","object","array"]},
        "canonicalRelation":{"type":"string","minLength":3},
        "calculationPass":{"type":"boolean"}
      }
    },
    "pairingEvidence":{
      "type":"object","additionalProperties":false,
      "required":["pairKey","baseFixtureId","sameNumericPrerequisites","sameNumberDomain","semanticDeltaOnly"],
      "properties":{
        "pairKey":{"type":"string","minLength":3},
        "baseFixtureId":{"type":["string","null"]},
        "sameNumericPrerequisites":{"type":"boolean"},
        "sameNumberDomain":{"type":"boolean"},
        "semanticDeltaOnly":{"type":"boolean"}
      }
    },
    "interpretationEvidence":{
      "type":"object","additionalProperties":false,
      "required":["required","provided","interpretiveAct","statement","counterfactualApplied","crossContextApplied"],
      "properties":{
        "required":{"type":"boolean"},"provided":{"type":"boolean"},
        "interpretiveAct":{"type":["string","null"]},"statement":{"type":"string"},
        "counterfactualApplied":{"type":"boolean"},"crossContextApplied":{"type":"boolean"}
      }
    },
    "misconceptionEvidence":{
      "type":"object","additionalProperties":false,
      "required":["triggered","misconceptionId","misconceptionType","diagnosticClassification"],
      "properties":{
        "triggered":{"type":"boolean"},
        "misconceptionId":{"type":["string","null"]},
        "misconceptionType":{"type":["string","null"]},
        "diagnosticClassification":{"type":["string","null"]}
      }
    },
    "uniquenessEvidence":{
      "type":"object","additionalProperties":false,
      "required":["answerCardinality","witnessCardinality"],
      "properties":{
        "answerCardinality":{"type":"integer","minimum":1},
        "witnessCardinality":{"type":"integer","minimum":1}
      }
    },
    "pblEvidence":{
      "type":"object","additionalProperties":false,
      "required":["required","taskIds","milestoneIds","dependencies","finalTaskId","finalRequiredMilestoneIds"],
      "properties":{
        "required":{"type":"boolean"},
        "taskIds":{"type":"array","items":{"type":"string"},"uniqueItems":true},
        "milestoneIds":{"type":"array","items":{"type":"string"},"uniqueItems":true},
        "dependencies":{
          "type":"array",
          "items":{
            "type":"object","additionalProperties":false,
            "required":["taskId","inputRefs"],
            "properties":{"taskId":{"type":"string"},"inputRefs":{"type":"array","items":{"type":"string"}}}
          }
        },
        "finalTaskId":{"type":["string","null"]},
        "finalRequiredMilestoneIds":{"type":"array","items":{"type":"string"},"uniqueItems":true}
      }
    },
    "expectedValidation":{
      "type":"object","additionalProperties":false,
      "required":["shouldPass","expectedErrorCode","expectedCalculationPass","expectedInterpretationPass","expectedUniquenessPass","expectedPBLPass"],
      "properties":{
        "shouldPass":{"type":"boolean"},
        "expectedErrorCode":{"type":["string","null"]},
        "expectedCalculationPass":{"type":"boolean"},
        "expectedInterpretationPass":{"type":"boolean"},
        "expectedUniquenessPass":{"type":"boolean"},
        "expectedPBLPass":{"type":"boolean"}
      }
    },
    "productionAdmissionAllowed":{"const":false},
    "lineage":{
      "type":"object","additionalProperties":false,
      "required":["a02BindingCandidateId","a03ProofCandidateId","a03PBLCandidateId","a04PolicyPath"],
      "properties":{
        "a02BindingCandidateId":{"type":"string","pattern":"^w02_bind_"},
        "a03ProofCandidateId":{"type":["string","null"]},
        "a03PBLCandidateId":{"type":["string","null"]},
        "a04PolicyPath":{"const":"data/curriculum/application/assessment/w02-validator-fixture-shadow-policy.json"}
      }
    }
  }
}
