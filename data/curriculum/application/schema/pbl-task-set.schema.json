{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cobelinfuture-Kobel/taiwan-elementary-math-generator/data/curriculum/application/schema/pbl-task-set.schema.json",
  "title": "PBLTaskSetV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "pblTaskSetId",
    "sourceId",
    "primaryKnowledgePointId",
    "supportingKnowledgePointIds",
    "canonicalOperationModelIds",
    "applicationCapabilityIds",
    "globalContextFamilyId",
    "unitContextBindingId",
    "drivingProblem",
    "graphType",
    "tasks",
    "milestones",
    "finalProduct",
    "authenticityEvidence",
    "primaryInterpretiveAct",
    "interpretationWitnessTaskIds",
    "misconceptionModels",
    "counterfactualVariant",
    "validationContract",
    "approvedProjection",
    "admissionStatus",
    "lineage"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "pblTaskSetId": { "type": "string", "pattern": "^pbl_" },
    "sourceId": { "type": "string", "minLength": 3 },
    "primaryKnowledgePointId": { "type": "string", "pattern": "^kp_" },
    "supportingKnowledgePointIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^kp_" },
      "uniqueItems": true
    },
    "canonicalOperationModelIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^op_" },
      "uniqueItems": true
    },
    "applicationCapabilityIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 },
      "uniqueItems": true
    },
    "globalContextFamilyId": { "type": "string", "pattern": "^gctx_" },
    "unitContextBindingId": { "type": "string", "minLength": 3 },
    "drivingProblem": { "$ref": "#/$defs/drivingProblem" },
    "graphType": {
      "enum": ["PBL3_LINEAR", "PBL4_BRANCH_MERGE", "PBL5_BOUNDED_DECISION"]
    },
    "tasks": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/taskNode" }
    },
    "milestones": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/milestone" }
    },
    "finalProduct": { "$ref": "#/$defs/finalProduct" },
    "authenticityEvidence": { "$ref": "#/$defs/authenticityEvidence" },
    "primaryInterpretiveAct": {
      "enum": [
        "UNKNOWN_ROLE_SHIFT",
        "REMAINDER_INTERPRETATION",
        "RELATION_CHAIN",
        "DUAL_CONSTRAINT_RESOLUTION",
        "CONSERVATION_OR_TRANSFER",
        "COMPARISON_DECISION",
        "UNIT_ROLE_INTERPRETATION",
        "IRRELEVANT_INFORMATION_FILTER"
      ]
    },
    "interpretationWitnessTaskIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 },
      "uniqueItems": true
    },
    "calculationPassInterpretationFailModelExists": { "const": true },
    "misconceptionModels": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/misconceptionModel" },
      "contains": {
        "type": "object",
        "properties": {
          "diagnosticClassification": {
            "const": "CALCULATION_PASS_INTERPRETATION_FAIL"
          }
        },
        "required": ["diagnosticClassification"]
      },
      "minContains": 1
    },
    "counterfactualVariant": { "$ref": "#/$defs/counterfactualVariant" },
    "validationContract": { "$ref": "#/$defs/validationContract" },
    "approvedProjection": {
      "enum": ["APPROVED_COMPLETE_SINGLE_PAGE", "APPROVED_COMPLETE_TWO_PAGE"]
    },
    "admissionStatus": {
      "enum": [
        "PBL_DRAFT",
        "DRIVING_PROBLEM_VERIFIED",
        "DEPENDENCY_GRAPH_VERIFIED",
        "MILESTONE_CLOSURE_VERIFIED",
        "FINAL_PRODUCT_VERIFIED",
        "AUTHENTICITY_VERIFIED",
        "PROJECTION_VERIFIED",
        "PBL_VALIDATED_CANDIDATE",
        "PBL_PRODUCTION_ADMITTED",
        "REJECTED_BROKEN_DEPENDENCY",
        "REJECTED_MISSING_MILESTONE",
        "REJECTED_MISSING_FINAL_PRODUCT",
        "REJECTED_DECORATIVE_CONTEXT",
        "REJECTED_UNAPPROVED_PROJECTION"
      ]
    },
    "lineage": { "$ref": "#/$defs/lineage" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "graphType": { "const": "PBL3_LINEAR" } },
        "required": ["graphType"]
      },
      "then": {
        "properties": { "tasks": { "minItems": 3, "maxItems": 3 } }
      }
    },
    {
      "if": {
        "properties": { "graphType": { "const": "PBL4_BRANCH_MERGE" } },
        "required": ["graphType"]
      },
      "then": {
        "properties": { "tasks": { "minItems": 4, "maxItems": 4 } }
      }
    },
    {
      "if": {
        "properties": { "graphType": { "const": "PBL5_BOUNDED_DECISION" } },
        "required": ["graphType"]
      },
      "then": {
        "properties": { "tasks": { "minItems": 5, "maxItems": 5 } }
      }
    }
  ],
  "$defs": {
    "drivingProblem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stakeholder",
        "realWorldGoal",
        "problemStatementZh",
        "constraints",
        "successCriteria",
        "consequenceOfIncorrectDecision",
        "finalProductType"
      ],
      "properties": {
        "stakeholder": { "type": "string", "minLength": 2 },
        "realWorldGoal": { "type": "string", "minLength": 5 },
        "problemStatementZh": { "type": "string", "minLength": 15 },
        "constraints": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3 }
        },
        "successCriteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3 }
        },
        "consequenceOfIncorrectDecision": { "type": "string", "minLength": 5 },
        "finalProductType": {
          "enum": [
            "ALLOCATION_PLAN",
            "PURCHASE_DECISION",
            "BUDGET_RECOMMENDATION",
            "TRANSPORT_PLAN",
            "PACKAGING_PLAN",
            "SCHEDULE",
            "COMPARISON_REPORT",
            "RESOURCE_PLAN"
          ]
        }
      }
    },
    "taskNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "taskId",
        "sequenceIndex",
        "promptZh",
        "inputRefs",
        "outputMilestoneId",
        "knowledgePointIds",
        "operationModelIds",
        "numericWitnessContract",
        "interpretationWitnessContract",
        "isFinalTask"
      ],
      "properties": {
        "taskId": { "type": "string", "minLength": 2 },
        "sequenceIndex": { "type": "integer", "minimum": 1, "maximum": 5 },
        "promptZh": { "type": "string", "minLength": 8 },
        "inputRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "uniqueItems": true
        },
        "outputMilestoneId": { "type": "string", "minLength": 2 },
        "knowledgePointIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^kp_" },
          "uniqueItems": true
        },
        "operationModelIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^op_" },
          "uniqueItems": true
        },
        "numericWitnessContract": { "type": "string", "minLength": 3 },
        "interpretationWitnessContract": { "type": "string", "minLength": 3 },
        "isFinalTask": { "type": "boolean" }
      }
    },
    "milestone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "milestoneId",
        "producerTaskId",
        "semanticRole",
        "valueType",
        "unit",
        "requiredByTaskIds",
        "canonicalReconstruction"
      ],
      "properties": {
        "milestoneId": { "type": "string", "minLength": 2 },
        "producerTaskId": { "type": "string", "minLength": 2 },
        "semanticRole": { "type": "string", "minLength": 2 },
        "valueType": { "enum": ["INTEGER", "DECIMAL", "FRACTION", "DECISION", "PLAN", "COMPARISON"] },
        "unit": { "type": "string", "minLength": 1 },
        "requiredByTaskIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "uniqueItems": true
        },
        "canonicalReconstruction": { "type": "string", "minLength": 3 }
      }
    },
    "finalProduct": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finalProductType",
        "finalTaskId",
        "requiredMilestoneIds",
        "decisionOrProductModel",
        "decisionWitness",
        "constraintSatisfactionChecks"
      ],
      "properties": {
        "finalProductType": {
          "enum": [
            "ALLOCATION_PLAN",
            "PURCHASE_DECISION",
            "BUDGET_RECOMMENDATION",
            "TRANSPORT_PLAN",
            "PACKAGING_PLAN",
            "SCHEDULE",
            "COMPARISON_REPORT",
            "RESOURCE_PLAN"
          ]
        },
        "finalTaskId": { "type": "string", "minLength": 2 },
        "requiredMilestoneIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 2 },
          "uniqueItems": true
        },
        "decisionOrProductModel": { "type": "object" },
        "decisionWitness": {
          "type": "object",
          "additionalProperties": false,
          "required": ["selectedDecisionOrPlan", "supportingMilestoneIds", "constraintChecks", "shortJustification"],
          "properties": {
            "selectedDecisionOrPlan": {},
            "supportingMilestoneIds": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 2 },
              "uniqueItems": true
            },
            "constraintChecks": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 3 }
            },
            "shortJustification": { "type": "string", "minLength": 5 }
          }
        },
        "constraintSatisfactionChecks": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3 }
        }
      }
    },
    "authenticityEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contextNecessaryForDecision",
        "removingContextDestroysTaskMeaning",
        "finalProductUsableInContext",
        "constraintsAreEventRealistic"
      ],
      "properties": {
        "contextNecessaryForDecision": { "const": true },
        "removingContextDestroysTaskMeaning": { "const": true },
        "finalProductUsableInContext": { "const": true },
        "constraintsAreEventRealistic": { "const": true }
      }
    },
    "misconceptionModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["misconceptionId", "earliestDetectedTaskId", "diagnosticClassification", "diagnosticMeaning"],
      "properties": {
        "misconceptionId": { "type": "string", "minLength": 3 },
        "earliestDetectedTaskId": { "type": "string", "minLength": 2 },
        "diagnosticClassification": {
          "enum": [
            "CALCULATION_FAIL",
            "CALCULATION_PASS_INTERPRETATION_FAIL",
            "DEPENDENCY_FAIL",
            "CONSTRAINT_DECISION_FAIL",
            "ANSWER_ROLE_OR_UNIT_FAIL"
          ]
        },
        "diagnosticMeaning": { "type": "string", "minLength": 3 }
      }
    },
    "counterfactualVariant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changedConstraint", "expectedAffectedTaskIds", "expectedMilestoneChanges", "expectedFinalProductChange"],
      "properties": {
        "changedConstraint": { "type": "string", "minLength": 3 },
        "expectedAffectedTaskIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 2 }
        },
        "expectedMilestoneChanges": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3 }
        },
        "expectedFinalProductChange": { "type": "string", "minLength": 3 }
      }
    },
    "validationContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identityAndAuthority",
        "math",
        "semanticRole",
        "dependency",
        "milestoneCompleteness",
        "decision",
        "authenticity",
        "projection",
        "blockingFailureReturnsNoTaskSet"
      ],
      "properties": {
        "identityAndAuthority": { "const": true },
        "math": { "const": true },
        "semanticRole": { "const": true },
        "dependency": { "const": true },
        "milestoneCompleteness": { "const": true },
        "decision": { "const": true },
        "authenticity": { "const": true },
        "projection": { "const": true },
        "blockingFailureReturnsNoTaskSet": { "const": true }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["knowledgeOperationAuthorityPaths", "globalContextAuthorityPath", "unitContextBindingAuthorityPath"],
      "properties": {
        "knowledgeOperationAuthorityPaths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^data/curriculum/knowledge/units/" }
        },
        "globalContextAuthorityPath": { "type": "string", "pattern": "^data/curriculum/context/registry/" },
        "unitContextBindingAuthorityPath": { "type": "string", "pattern": "^data/curriculum/context/registry/" }
      }
    }
  }
}
