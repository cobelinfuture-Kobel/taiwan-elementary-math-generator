{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cobelinfuture-Kobel/taiwan-elementary-math-generator/data/curriculum/application/schema/w01-worksheet-shadow-projection.schema.json",
  "title": "POSTGAPPW01WorksheetShadowProjectionV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion","worksheetProjectionId","sourceId","sourceNodeRefs","questionItems","answerKeyItems","nPlusOneEvidenceRefs","pblSections","pagePlan","shadowHtml","projectionStatus","productionSelectable"],
  "properties": {
    "schemaVersion":{"const":1},
    "worksheetProjectionId":{"type":"string","pattern":"^w01_ws_shadow_"},
    "sourceId":{"type":"string","pattern":"^g[3-6][ab]_u"},
    "sourceNodeRefs":{"type":"array","minItems":1,"items":{"type":"string"},"uniqueItems":true},
    "questionItems":{"type":"array","minItems":1,"items":{"type":"object","required":["questionId","bindingCandidateId","knowledgePointId","promptZh","contextMacroId","answerShape"],"properties":{"questionId":{"type":"string"},"bindingCandidateId":{"type":"string","pattern":"^w01_bind_"},"knowledgePointId":{"type":"string","pattern":"^kp_"},"promptZh":{"type":"string","minLength":10},"contextMacroId":{"type":"string","pattern":"^gctx_macro_"},"answerShape":{"type":"string"}}}},
    "answerKeyItems":{"type":"array","minItems":1,"items":{"type":"object","required":["questionId","answerPayload","answerRole","answerUnitCandidate","interpretationStatementCandidate"],"properties":{"questionId":{"type":"string"},"answerPayload":{},"answerRole":{"type":"string"},"answerUnitCandidate":{"type":"string"},"interpretationStatementCandidate":{"type":"string"}}}},
    "nPlusOneEvidenceRefs":{"type":"array","items":{"type":"string","pattern":"^w01_n1proof_"},"uniqueItems":true},
    "pblSections":{"type":"array","items":{"type":"object","required":["pblCandidateId","graphType","projectionCandidate","taskIds","milestoneIds","finalTaskId"],"properties":{"pblCandidateId":{"type":"string","pattern":"^w01_pbl_"},"graphType":{"enum":["PBL3_LINEAR","PBL5_BOUNDED_DECISION"]},"projectionCandidate":{"enum":["APPROVED_COMPLETE_SINGLE_PAGE_CANDIDATE","APPROVED_COMPLETE_TWO_PAGE_CANDIDATE"]},"taskIds":{"type":"array","minItems":3,"items":{"type":"string"}},"milestoneIds":{"type":"array","minItems":2,"items":{"type":"string"}},"finalTaskId":{"type":"string"}}}},
    "pagePlan":{"enum":["APPROVED_COMPLETE_SINGLE_PAGE_CANDIDATE","APPROVED_COMPLETE_TWO_PAGE_CANDIDATE"]},
    "shadowHtml":{"type":"string","minLength":50},
    "projectionStatus":{"const":"SHADOW_STRUCTURAL_PROJECTION"},
    "productionSelectable":{"const":false}
  }
}
