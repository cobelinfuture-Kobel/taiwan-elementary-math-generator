{
  "name": "math-worksheet-generator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "pretest": "node --input-type=module -e \"import('./tools/curriculum/audit-15-unit-public-worksheet-closeout.mjs').then(({auditFifteenUnitPublicWorksheetCloseout:a})=>{const r=a();console.log('CLOSEOUT_METRICS='+JSON.stringify(r.metrics));console.log('CLOSEOUT_BLOCKERS='+JSON.stringify(r.rows.filter(x=>x.blockers.length).map(({sourceId,blockers,errors})=>({sourceId,blockers,errors}))));})\"",
    "test": "node --test",
    "governance:claims": "node tools/governance/validate-milestone-claim-integrity.mjs",
    "governance:claims:pr": "node tools/governance/validate-milestone-claim-integrity.mjs --require-pr-manifest",
    "preview:build": "node tools/preview/generate-generator-backed-preview-html.js",
    "preview:serve": "node tools/preview/serve-preview.js",
    "site:serve": "node tools/site/serve-site.js"
  }
}
